# ─── Database ─────────────────────────────────────────────────
# Neon PostgreSQL — get from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AI (Groq) ────────────────────────────────────────────────
# Get free API key from https://console.groq.com
GROQ_API_KEY="gsk_..."

# ─── Email (Resend) ───────────────────────────────────────────
# Get free API key from https://resend.com — 3,000 emails/month free
RESEND_API_KEY="re_..."
# Must be a verified domain in Resend dashboard
RESEND_FROM_EMAIL="Codentia <noreply@yourdomain.com>"

# ─── File Storage (Cloudflare R2) ─────────────────────────────
# Create a bucket at https://dash.cloudflare.com → R2
# All free up to 10GB/month storage, 1M Class A ops
STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID="your-r2-access-key"
STORAGE_SECRET_ACCESS_KEY="your-r2-secret-key"
STORAGE_BUCKET_NAME="codentia-uploads"
# Enable R2 public bucket URL in dashboard
STORAGE_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ─── Cron Protection ──────────────────────────────────────────
# Generate: openssl rand -base64 32  — used to protect /api/cron/reminders
CRON_SECRET="your-cron-secret-here"

# ─── Paystack (payments) ─────────────────────────────────────
# Sign up free at https://paystack.com — Nigerian business, supports NGN + USD
# No install needed — uses REST API directly
# Get keys from: Paystack Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY="sk_live_..."     # or sk_test_... for testing
PAYSTACK_PUBLIC_KEY="pk_live_..."     # used on frontend if needed
# Webhook URL: https://yourdomain.com/api/paystack/webhook
# (Set this in Paystack Dashboard → Settings → API Keys & Webhooks)

# Exchange rate for NGN pricing (course prices stored in USD, converted at checkout)
# Update this whenever you want to adjust the NGN rate
USD_TO_NGN_RATE=1600
NEXT_PUBLIC_USD_TO_NGN_RATE=1600

# ─── Schema additions needed (run: npx prisma db push) ────────
# Add to Course model:  price Float?   @default(0)
# Add to Submission:    fileUrl String?
# Add models: PlatformSettings, UserPreferences (see prisma/migrations/add_platform_settings.sql)
