// Codentia Learning Platform — Prisma Schema v1.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubmissionStatus {
  PENDING
  AI_REVIEWED
  INSTRUCTOR_REVIEWED
  GRADED
}

enum LiveClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_LESSON
  ASSIGNMENT_FEEDBACK
  QUIZ_RESULT
  LIVE_CLASS_REMINDER
  ASSIGNMENT_DEADLINE
}

enum AIContext {
  LESSON
  ASSIGNMENT
  QUIZ
  GENERAL
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  bio           String?
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  preferences   UserPreferences?

  accounts      Account[]
  sessions      Session[]

  enrollments         Enrollment[]
  progressRecords     ProgressRecord[]
  quizResults         QuizResult[]
  submissions         Submission[]
  liveClassAttendance LiveClassAttendance[]
  notifications       Notification[]
  aiInteractions      AIInteraction[]

  @@map("users")
}

// NextAuth models unchanged
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// COURSES
// ─────────────────────────────────────────────

model Course {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  thumbnail   String?
  difficulty  Difficulty @default(BEGINNER)
  category    String?
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  price       Float?     @default(0)

  modules     Module[]
  enrollments Enrollment[]
  liveClasses LiveClass[]

  @@map("courses")
}

model Module {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
  @@map("modules")
}

model Lesson {
  id            String   @id @default(cuid())
  title         String
  content       String?
  videoUrl      String?
  order         Int      @default(0)
  moduleId      String
  hasQuiz       Boolean  @default(false)
  hasAssignment Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz            Quiz?
  assignment      Assignment?
  progressRecords ProgressRecord[]
  resources       Resource[]

  @@index([moduleId, order])
  @@map("lessons")
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  url       String
  fileType  String?
  lessonId  String
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("resources")
}

// ─────────────────────────────────────────────
// ENROLLMENT & PROGRESS
// ─────────────────────────────────────────────

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model ProgressRecord {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("progress_records")
}

// ─────────────────────────────────────────────
// QUIZZES
// ─────────────────────────────────────────────

model Quiz {
  id        String   @id @default(cuid())
  title     String
  lessonId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  quizResults QuizResult[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(cuid())
  question      String
  order         Int      @default(0)
  quizId        String
  correctOption Int      @default(0)
  explanation   String?

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]

  @@map("quiz_questions")
}

model QuizOption {
  id         String @id @default(cuid())
  text       String
  order      Int    @default(0)
  questionId String

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_options")
}

model QuizResult {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  answers     Json
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_results")
}

// ─────────────────────────────────────────────
// ASSIGNMENTS
// ─────────────────────────────────────────────

model Assignment {
  id           String   @id @default(cuid())
  title        String
  description  String
  lessonId     String   @unique
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           String           @id @default(cuid())
  userId       String
  assignmentId String
  githubUrl    String?
  liveUrl      String?
  fileUrl      String?
  notes        String?
  status       SubmissionStatus @default(PENDING)
  grade        Int?
  feedback     String?
  aiFeedback   String?
  submittedAt  DateTime         @default(now())
  reviewedAt   DateTime?
 

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
  @@index([userId])
  @@map("submissions")
}

// ─────────────────────────────────────────────
// LIVE CLASSES
// ─────────────────────────────────────────────

model LiveClass {
  id           String          @id @default(cuid())
  title        String
  description  String?
  instructor   String
  courseId     String
  meetingLink  String
  scheduledAt  DateTime
  durationMins Int             @default(60)
  status       LiveClassStatus @default(SCHEDULED)
  recordingUrl String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  course     Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendance LiveClassAttendance[]

  @@map("live_classes")
}

model LiveClassAttendance {
  id          String    @id @default(cuid())
  userId      String
  liveClassId String
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@unique([userId, liveClassId])
  @@map("live_class_attendance")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AI INTERACTIONS
// ─────────────────────────────────────────────

model AIInteraction {
  id        String    @id @default(cuid())
  userId    String
  context   AIContext
  contextId String?
  prompt    String
  response  String
  tokens    Int?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_interactions")
}

model PlatformSettings {
  id                   String   @id @default("global")
  platformName         String   @default("Codentia")
  supportEmail         String   @default("hello@codentia.dev")
  timezone             String   @default("Africa/Lagos")
  logoUrl              String?
  aiCodingAssistant    Boolean  @default(true)
  aiAssignmentFeedback Boolean  @default(true)
  aiQuizGenerator      Boolean  @default(true)
  aiAtRiskDetection    Boolean  @default(true)
  pointsSystem         Boolean  @default(true)
  badges               Boolean  @default(true)
  leaderboard          Boolean  @default(true)
  emailLiveReminders   Boolean  @default(true)
  emailDeadlines       Boolean  @default(true)
  emailAiRecommend     Boolean  @default(true)
  emailReEngagement    Boolean  @default(true)
  emailNewCourse       Boolean  @default(true)
  updatedAt            DateTime @updatedAt
}

model UserPreferences {
  userId              String   @id
  emailNewLessons     Boolean  @default(true)
  emailDeadlines      Boolean  @default(true)
  emailClassReminders Boolean  @default(true)
  emailAiFeedback     Boolean  @default(true)
  timezone            String   @default("Africa/Lagos")
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}